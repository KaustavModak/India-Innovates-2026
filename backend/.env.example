# Application
APP_NAME=Election Audit API
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://audit_user:audit_pass@localhost:5432/election_audit

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# JWT - CHANGE THESE IN PRODUCTION
JWT_SECRET_KEY=dev-secret-key-change-in-production-immediately
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100
ALLOWED_EXTENSIONS=pdf,csv,xlsx,json,xml

# Blockchain
HLF_CHANNEL_NAME=electionchannel
HLF_CHAINCODE_NAME=election_audit
HLF_MSP_ID=Org1MSP

# Security
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=60
MFA_ISSUER_NAME=ElectionAudit
